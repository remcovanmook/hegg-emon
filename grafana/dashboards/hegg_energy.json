{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB v2 datasource writing hegg_reading and hegg_summary measurements",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "title": "Hegg Energy Monitor",
  "uid": "hegg-energy-monitor",
  "description": "Live and historical view of Hegg smart-meter data written by hegg_influx.py",
  "tags": ["hegg", "energy", "smart-meter"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "weekStart": "",
  "fiscalYearStartMonth": 0,
  "links": [],
  "annotations": { "list": [] },

  "templating": {
    "list": [
      {
        "name": "DS_INFLUXDB",
        "type": "datasource",
        "pluginId": "influxdb",
        "label": "InfluxDB datasource",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "bucket",
        "type": "textbox",
        "label": "Bucket",
        "description": "InfluxDB v2 bucket name",
        "query": "hegg",
        "current": { "text": "hegg", "value": "hegg" },
        "hide": 0
      },
      {
        "name": "serial",
        "type": "query",
        "label": "Device serial",
        "description": "Hegg device serial tag (leave .* for all)",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"serial\")",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "hide": 0,
        "current": {}
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Live readings",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "title": "Net Power",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue",  "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "delivered = from(bucket: \"${bucket}\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"hegg_reading\" and r._field == \"power_delivered\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> last()\nreturned = from(bucket: \"${bucket}\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"hegg_reading\" and r._field == \"power_returned\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> last()\njoin(tables: {d: delivered, r: returned}, on: [\"serial\", \"_time\"])\n  |> map(fn: (r) => ({_time: r._time, _value: (r._value_d - r._value_r) * 1000.0, _field: \"net_w\"}))"
        }
      ]
    },

    {
      "id": 3,
      "title": "Energy In",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "unit": "kwatth", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r._measurement == \"hegg_summary\")\n  |> filter(fn: (r) => r._field == \"energy_delivered_t1\" or r._field == \"energy_delivered_t2\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> last()\n  |> pivot(rowKey: [\"serial\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({_time: now(), _value: r.energy_delivered_t1 + r.energy_delivered_t2, _field: \"Energy In\"}))"
        }
      ]
    },

    {
      "id": 4,
      "title": "Energy Out",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "unit": "kwatth", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r._measurement == \"hegg_summary\")\n  |> filter(fn: (r) => r._field == \"energy_returned_t1\" or r._field == \"energy_returned_t2\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> last()\n  |> pivot(rowKey: [\"serial\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({_time: now(), _value: r.energy_returned_t1 + r.energy_returned_t2, _field: \"Energy Out\"}))"
        }
      ]
    },

    {
      "id": 5,
      "title": "Gas",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "unit": "m3", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "orange" } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r._measurement == \"hegg_summary\" and r._field == \"gas_delivered\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> last()\n  |> map(fn: (r) => ({r with _field: \"Gas\"}))"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "Power",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 }
    },

    {
      "id": 11,
      "title": "Power — Delivered & Returned",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 10 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "power_delivered" },
            "properties": [
              { "id": "displayName",        "value": "Delivered" },
              { "id": "color",              "value": { "mode": "fixed", "fixedColor": "#2563eb" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "power_returned" },
            "properties": [
              { "id": "displayName",        "value": "Returned" },
              { "id": "color",              "value": { "mode": "fixed", "fixedColor": "#16a34a" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hegg_reading\")\n  |> filter(fn: (r) => r._field == \"power_delivered\" or r._field == \"power_returned\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _value: r._value * 1000.0}))\n  |> yield(name: \"power_w\")"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Voltage & Current",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }
    },

    {
      "id": 21,
      "title": "Voltage — L1 / L2 / L3",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "voltage_l1" },
            "properties": [
              { "id": "displayName", "value": "L1" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#6366f1" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "voltage_l2" },
            "properties": [
              { "id": "displayName", "value": "L2" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#0ea5e9" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "voltage_l3" },
            "properties": [
              { "id": "displayName", "value": "L3" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#f97316" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hegg_reading\")\n  |> filter(fn: (r) => r._field == \"voltage_l1\" or r._field == \"voltage_l2\" or r._field == \"voltage_l3\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"voltage\")"
        }
      ]
    },

    {
      "id": 22,
      "title": "Current — L1 / L2 / L3",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "decimals": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "current_l1" },
            "properties": [
              { "id": "displayName", "value": "L1" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#6366f1" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "current_l2" },
            "properties": [
              { "id": "displayName", "value": "L2" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#0ea5e9" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "current_l3" },
            "properties": [
              { "id": "displayName", "value": "L3" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#f97316" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hegg_reading\")\n  |> filter(fn: (r) => r._field == \"current_l1\" or r._field == \"current_l2\" or r._field == \"current_l3\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"current\")"
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "Energy detail",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "title": "Energy Delivered — T1 & T2",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "energy_delivered_t1" },
            "properties": [
              { "id": "displayName", "value": "Delivered T1 (off-peak)" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#2563eb" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "energy_delivered_t2" },
            "properties": [
              { "id": "displayName", "value": "Delivered T2 (peak)" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#7c3aed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hegg_summary\")\n  |> filter(fn: (r) => r._field == \"energy_delivered_t1\" or r._field == \"energy_delivered_t2\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> yield(name: \"delivered\")"
        }
      ]
    },

    {
      "id": 32,
      "title": "Energy Returned — T1 & T2",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "energy_returned_t1" },
            "properties": [
              { "id": "displayName", "value": "Returned T1 (off-peak)" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#16a34a" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "energy_returned_t2" },
            "properties": [
              { "id": "displayName", "value": "Returned T2 (peak)" },
              { "id": "color",       "value": { "mode": "fixed", "fixedColor": "#0d9488" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hegg_summary\")\n  |> filter(fn: (r) => r._field == \"energy_returned_t1\" or r._field == \"energy_returned_t2\")\n  |> filter(fn: (r) => r.serial =~ /^${serial}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> yield(name: \"returned\")"
        }
      ]
    }

  ]
}
