[Unit]
Description=Hegg energy monitor — dashboard + Prometheus
Documentation=https://github.com/yourorg/hegg
After=network-online.target hegg-collector.service
Wants=network-online.target

[Service]
Type=simple
User=hegg
Group=hegg
WorkingDirectory=/opt/hegg
Environment=HEGG_DB=/var/lib/hegg/hegg.db
ExecStart=/opt/hegg/.venv/bin/python -m dashboard.app \
    --db ${HEGG_DB}
EnvironmentFile=-/etc/default/hegg
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
